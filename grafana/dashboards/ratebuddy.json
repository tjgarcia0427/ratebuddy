{
  "annotations": {"list": []},
  "editable": true,
  "schemaVersion": 39,
  "title": "ratebuddy",
  "uid": "ratebuddy-overview",
  "tags": ["ratebuddy", "rate-limit"],
  "time": {"from": "now-15m", "to": "now"},
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests / sec (last 1m)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(ratebuddy_requests_total[1m]))",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Deny rate (last 1m)",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(ratebuddy_requests_total{decision=\"denied\"}[1m])) / clamp_min(sum(rate(ratebuddy_requests_total[1m])), 1e-9)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "fieldOptions": {"defaults": {"unit": "percentunit"}}
      },
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Requests by algorithm (rps)",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [
        {
          "expr": "sum by (algorithm) (rate(ratebuddy_requests_total[1m]))",
          "refId": "A",
          "legendFormat": "{{algorithm}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Allowed vs Denied (rps)",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [
        {
          "expr": "sum by (decision) (rate(ratebuddy_requests_total[1m]))",
          "refId": "A",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Decision latency (p50/p95/p99)",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
      "datasource": {"type": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ratebuddy_consume_latency_seconds_bucket[1m])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ratebuddy_consume_latency_seconds_bucket[1m])))",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ratebuddy_consume_latency_seconds_bucket[1m])))",
          "refId": "C",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Redis errors (last 5m)",
      "gridPos": {"x": 0, "y": 20, "w": 6, "h": 4},
      "datasource": {"type": "prometheus"},
      "targets": [
        {
          "expr": "increase(ratebuddy_redis_errors_total[5m])",
          "refId": "A"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    }
  ]
}
